{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Session Manager",
  "version": "0.6.0",
  "identifier": "com.levit.claude-session-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "https://nobel6018.github.io/claude-session-manager"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Session Manager",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "dangerousRemoteDomainIpcAccess": [
        {
          "domain": "nobel6018.github.io",
          "windows": ["main"],
          "plugins": [],
          "enableTauriAPI": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
